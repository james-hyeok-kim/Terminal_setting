# ==========================================
# 1. 마우스 및 스크롤 설정
# ==========================================
# 마우스 휠 스크롤, 패널 클릭, 창 크기 조절 활성화
set -g mouse on

# 스크롤(히스토리) 기억 한도를 10000줄로 대폭 늘림 (기본 2000줄)
set -g history-limit 10000

# ==========================================
# 2. 복사 모드 (Copy Mode) 설정
# ==========================================
# 복사 모드에서 단축키를 vi 스타일로 사용
setw -g mode-keys vi

# 마우스로 드래그해서 선택 후, 마우스 버튼을 떼면 자동으로 복사하고 빠져나옴
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-selection-and-cancel

# ==========================================
# 3. 사용자 편의 설정
# ==========================================
# 창(Window)과 패널(Pane) 번호를 1부터 시작 (숫자키 0은 너무 멀리 있으니까요!)
set -g base-index 1
setw -g pane-base-index 1

# 터미널 색상 깨짐 방지 (vim 등에서 색상이 예쁘게 나오도록)
set -g default-terminal "screen-256color"

# (선택) Esc 키를 눌렀을 때의 딜레이 없애기 (vim 사용자 필수)
set -sg escape-time 0
